<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Tomlyn</id>
    <version>2.9.0</version>
    <authors>Alexandre Mutel</authors>
    <license type="expression">BSD-2-Clause</license>
    <licenseUrl>https://licenses.nuget.org/BSD-2-Clause</licenseUrl>
    <icon>Tomlyn.png</icon>
    <readme>readme.md</readme>
    <projectUrl>https://xoofx.github.io/Tomlyn/</projectUrl>
    <description>Tomlyn is a high-performance .NET TOML 1.1 parser, round-trippable syntax tree, and `System.Text.Json`-style object serializer - NativeAOT ready.</description>
    <releaseNotes>https://github.com/xoofx/Tomlyn/releases/tag/2.9.0</releaseNotes>
    <copyright>Alexandre Mutel</copyright>
    <tags>toml parser serialization deserialization nativeaot</tags>
    <repository type="git" url="https://github.com/xoofx/Tomlyn" commit="d7289dd53c04d76855cfd83efb52c399c4caf4ca" />
    <dependencies>
      <group targetFramework="net10.0" />
      <group targetFramework="net8.0" />
      <group targetFramework=".NETStandard2.0">
        <dependency id="System.Buffers" version="4.6.1" exclude="Build,Analyzers" />
        <dependency id="System.Collections.Immutable" version="9.0.0" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="10.0.2" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>